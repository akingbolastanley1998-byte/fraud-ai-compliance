    "# ══════════════════════════════════════════════════════════\n",
    "# FORMATTED RISK REGISTER\n",
    "# ══════════════════════════════════════════════════════════\n",
    "\n",
    "def severity_icon(s):\n",
    "    if s == \"Critical\": return \"🔴\"\n",
    "    if s == \"High\":     return \"🟠\"\n",
    "    if s == \"Medium\":   return \"🟡\"\n",
    "    return \"🟢\"\n",
    "\n",
    "display_df = RISKS[[\"ID\",\"Stakeholder\",\"Risk\",\"L\",\"I\",\"Score\",\"Severity\",\"Regulation\",\"Mitigation\"]].copy()\n",
    "display_df[\"Sev\"] = display_df[\"Severity\"].apply(severity_icon)\n",
    "display_df.insert(6, \"⚡\", display_df.pop(\"Sev\"))\n",
    "\n",
    "print(\"=\"*100)\n",
    "print(\"  RISK REGISTER — AI Fraud Detection System | Sorted by Severity Score (Highest First)\")\n",
    "print(\"=\"*100)\n",
    "print(display_df[[\"ID\",\"Stakeholder\",\"Risk\",\"L\",\"I\",\"Score\",\"⚡\",\"Severity\"]].to_string(index=False))\n",
    "\n",
    "# Plotly interactive table\n",
    "fig = go.Figure(data=[go.Table(\n",
    "    header=dict(\n",
    "        values=[\"<b>ID</b>\",\"<b>Stakeholder</b>\",\"<b>Risk</b>\",\"<b>L</b>\",\"<b>I</b>\",\n",
    "                \"<b>Score</b>\",\"<b>Severity</b>\",\"<b>Regulation</b>\",\"<b>Mitigation</b>\"],\n",
    "        fill_color=\"#1e3a5f\",\n",
    "        font=dict(color=\"white\", size=12),\n",
    "        align=\"left\", height=35,\n",
    "    ),\n",
    "    cells=dict(\n",
    "        values=[\n",
    "            RISKS[\"ID\"], RISKS[\"Stakeholder\"], RISKS[\"Risk\"],\n",
    "            RISKS[\"L\"], RISKS[\"I\"], RISKS[\"Score\"], RISKS[\"Severity\"],\n",
    "            RISKS[\"Regulation\"], RISKS[\"Mitigation\"]\n",
    "        ],\n",
    "        fill_color=[\n",
    "            [\"#112240\"]*len(RISKS),\n",
    "            [\"#112240\"]*len(RISKS),\n",
    "            [\"#112240\"]*len(RISKS),\n",
    "            [\"#112240\"]*len(RISKS),\n",
    "            [\"#112240\"]*len(RISKS),\n",
    "            [\"rgba(239,68,68,0.2)\" if s>=16 else \"rgba(249,115,22,0.2)\" if s>=12 else\n",
    "             \"rgba(245,158,11,0.2)\" if s>=6 else \"rgba(34,197,94,0.2)\"\n",
    "             for s in RISKS[\"Score\"]],\n",
    "            [\"rgba(239,68,68,0.2)\" if s>=16 else \"rgba(249,115,22,0.2)\" if s>=12 else\n",
    "             \"rgba(245,158,11,0.2)\" if s>=6 else \"rgba(34,197,94,0.2)\"\n",
    "             for s in RISKS[\"Score\"]],\n",
    "            [\"#112240\"]*len(RISKS),\n",
    "            [\"#112240\"]*len(RISKS),\n",
    "        ],\n",
    "        font=dict(color=\"white\", size=11),\n",
    "        align=\"left\", height=30,\n",
    "    )\n",
    ")])\n",
    "fig.update_layout(\n",
    "    title=\"Risk Register — AI Fraud Detection System\",\n",
    "    paper_bgcolor=\"#070d1a\", plot_bgcolor=\"#070d1a\",\n",
    "    font=dict(color=\"white\"),\n",
    "    margin=dict(l=0,r=0,t=40,b=0), height=400,\n",
    ")\n",
    "fig.write_html(\"risk_register.html\")\n",
    "fig.show()\n",
    "print(\"\\n✅ Interactive risk register saved: risk_register.html\")\n"
   ]
