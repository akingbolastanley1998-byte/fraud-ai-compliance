   "source": [
    "## 3. Stakeholder Risk Heatmap"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "530dd781",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ══════════════════════════════════════════════════════════\n",
    "# RISK REGISTER DATA\n",
    "# ══════════════════════════════════════════════════════════\n",
    "\n",
    "RISKS = pd.DataFrame([\n",
    "    {\"ID\":\"R-01\",\"Stakeholder\":\"Bank Customers\",    \"Risk\":\"False Positive — Legitimate transaction blocked\",        \"L\":4,\"I\":4,\"Regulation\":\"FCA Consumer Duty; Art.22 GDPR\",\"Mitigation\":\"Human review threshold; 24hr appeal SLA\"},\n",
    "    {\"ID\":\"R-02\",\"Stakeholder\":\"Bank Customers\",    \"Risk\":\"Discriminatory fraud scoring (indirect discrimination)\", \"L\":3,\"I\":5,\"Regulation\":\"Equality Act s.19; EU AI Act Art.10\",\"Mitigation\":\"Quarterly bias audit; demographic parity testing\"},\n",
    "    {\"ID\":\"R-03\",\"Stakeholder\":\"Bank Customers\",    \"Risk\":\"No explanation for blocked payment\",                     \"L\":5,\"I\":3,\"Regulation\":\"UK GDPR Arts.13-14; EU AI Act Art.13\",\"Mitigation\":\"SHAP explanation module; customer decision letter\"},\n",
    "    {\"ID\":\"R-04\",\"Stakeholder\":\"Fraud Analysts\",    \"Risk\":\"Automation bias — over-reliance on AI score\",           \"L\":4,\"I\":4,\"Regulation\":\"EU AI Act Art.14 (Human Oversight)\",\"Mitigation\":\"Override tracking; calibration training; UI friction\"},\n",
    "    {\"ID\":\"R-05\",\"Stakeholder\":\"Fraud Analysts\",    \"Risk\":\"Alert fatigue reducing decision quality\",                \"L\":4,\"I\":3,\"Regulation\":\"EU AI Act Art.14(4)(e); NIST AI RMF\",\"Mitigation\":\"Threshold optimisation; tiered alert queues\"},\n",
    "    {\"ID\":\"R-06\",\"Stakeholder\":\"The Bank\",          \"Risk\":\"Model drift causing performance degradation\",            \"L\":3,\"I\":4,\"Regulation\":\"EU AI Act Arts.9,15; FCA PS21/3\",\"Mitigation\":\"Continuous monitoring; automated retraining\"},\n",
    "    {\"ID\":\"R-07\",\"Stakeholder\":\"The Bank\",          \"Risk\":\"Regulatory non-compliance (FCA, ICO, EU AI Act)\",       \"L\":3,\"I\":5,\"Regulation\":\"EU AI Act Arts.9-17; UK GDPR; Consumer Duty\",\"Mitigation\":\"Annual audit; DPIA; EU AI Act readiness programme\"},\n",
    "    {\"ID\":\"R-08\",\"Stakeholder\":\"ML Vendor\",         \"Risk\":\"Opaque model — accountability gap at vendor boundary\",  \"L\":4,\"I\":4,\"Regulation\":\"EU AI Act Art.25; contractual liability\",\"Mitigation\":\"Contractual XAI requirements; right-to-audit clause\"},\n",
    "    {\"ID\":\"R-09\",\"Stakeholder\":\"The Bank\",          \"Risk\":\"Data poisoning / adversarial attack on training data\",  \"L\":2,\"I\":5,\"Regulation\":\"EU AI Act Art.15; NIS2; NCSC ML Guidelines\",\"Mitigation\":\"Data provenance controls; ML red-team testing\"},\n",
    "    {\"ID\":\"R-10\",\"Stakeholder\":\"Regulators\",        \"Risk\":\"Systemic discrimination at scale across sector\",        \"L\":2,\"I\":5,\"Regulation\":\"EU AI Act Recital 47; Equality Act; FCA Principle 6\",\"Mitigation\":\"Sector audit regime; mandatory incident reporting\"},\n",
    "])\n",
    "\n",
    "RISKS[\"Score\"] = RISKS[\"L\"] * RISKS[\"I\"]\n",
    "RISKS[\"Severity\"] = RISKS[\"Score\"].apply(lambda s: \"Critical\" if s>=16 else \"High\" if s>=12 else \"Medium\" if s>=6 else \"Low\")\n",
    "RISKS = RISKS.sort_values(\"Score\", ascending=False)\n",
    "\n",
    "# ── Build 5×5 heatmap matrix ──────────────────────────────\n",
    "matrix = pd.DataFrame(0, index=range(5,0,-1), columns=range(1,6))\n",
    "matrix.index.name = \"Likelihood\"\n",
    "matrix.columns.name = \"Impact\"\n",
    "\n",
    "for _, r in RISKS.iterrows():\n",
    "    matrix.loc[r[\"L\"], r[\"I\"]] += 1\n",
    "\n",
    "# Colour map: dark navy → amber → red\n",
    "colours = [\"#0d1b2e\",\"#1a3a2a\",\"#2d5a2a\",\"#f59e0b\",\"#f97316\",\"#ef4444\"]\n",
    "cmap = LinearSegmentedColormap.from_list(\"risk\", colours, N=256)\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(18, 7),\n",
    "                          gridspec_kw={\"width_ratios\": [1.2, 1]})\n",
    "fig.patch.set_facecolor(\"#070d1a\")\n",
    "\n",
    "# Left: Heatmap\n",
    "ax = axes[0]\n",
    "base = pd.DataFrame([[l*i for i in range(1,6)] for l in range(5,0,-1)],\n",
    "                    index=range(5,0,-1), columns=range(1,6))\n",
    "sns.heatmap(base, ax=ax, cmap=cmap, vmin=1, vmax=25,\n",
    "            linewidths=0.5, linecolor=\"#112240\",\n",
    "            cbar_kws={\"label\": \"Risk Score (L×I)\"}, annot=True,\n",
    "            fmt=\"d\", annot_kws={\"color\":\"white\",\"size\":11,\"alpha\":0.4})\n",
    "\n",
    "# Plot risk dots on heatmap\n",
    "for _, r in RISKS.iterrows():\n",
    "    y = 5 - r[\"L\"] + 0.5\n",
    "    x = r[\"I\"] - 0.5\n",
    "    col = \"#ef4444\" if r[\"Score\"]>=16 else \"#f97316\" if r[\"Score\"]>=12 else \"#f59e0b\" if r[\"Score\"]>=6 else \"#22c55e\"\n",
    "    ax.plot(x, y, \"o\", color=col, markersize=18, alpha=0.85,\n",
    "            markeredgecolor=\"#070d1a\", markeredgewidth=2)\n",
    "    ax.text(x, y, r[\"ID\"].replace(\"R-\",\"R\\n\"), ha=\"center\", va=\"center\",\n",
    "            fontsize=6.5, color=\"white\", fontweight=\"bold\")\n",
    "\n",
    "ax.set_title(\"Risk Heatmap — Likelihood × Impact\\n(All 10 Risks Plotted)\",\n",
    "             color=\"white\", fontsize=12, fontweight=\"bold\")\n",
    "ax.set_xlabel(\"Impact →\", color=\"#8899bb\"); ax.set_ylabel(\"Likelihood →\", color=\"#8899bb\")\n",
    "ax.tick_params(colors=\"#8899bb\")\n",
    "\n",
    "# Right: Risk distribution bar chart\n",
    "ax2 = axes[1]\n",
    "severity_counts = RISKS[\"Severity\"].value_counts().reindex([\"Critical\",\"High\",\"Medium\",\"Low\"], fill_value=0)\n",
    "bar_colours = [\"#ef4444\",\"#f97316\",\"#f59e0b\",\"#22c55e\"]\n",
    "bars = ax2.barh(severity_counts.index, severity_counts.values,\n",
    "                color=bar_colours, edgecolor=\"#070d1a\", linewidth=2, height=0.6)\n",
    "\n",
    "for bar, val in zip(bars, severity_counts.values):\n",
    "    ax2.text(bar.get_width() + 0.05, bar.get_y() + bar.get_height()/2,\n",
    "             f\" {val} risk{'s' if val!=1 else ''}\", va=\"center\",\n",
    "             color=\"white\", fontsize=12, fontweight=\"bold\")\n",
    "\n",
    "ax2.set_facecolor(\"#112240\"); ax2.set_xlim(0, 5)\n",
    "ax2.set_title(\"Risk Distribution by Severity\",\n",
    "              color=\"white\", fontsize=12, fontweight=\"bold\")\n",
    "ax2.tick_params(colors=\"#8899bb\"); ax2.set_xlabel(\"Count\", color=\"#8899bb\")\n",
    "ax2.spines[[\"top\",\"right\",\"bottom\",\"left\"]].set_color(\"#1e3a5f\")\n",
    "\n",
    "# Legend\n",
    "legend_handles = [\n",
    "    mpatches.Patch(color=\"#ef4444\", label=f\"Critical (≥16): {(RISKS['Score']>=16).sum()}\"),\n",
    "    mpatches.Patch(color=\"#f97316\", label=f\"High (12-15):   {((RISKS['Score']>=12)&(RISKS['Score']<16)).sum()}\"),\n",
    "    mpatches.Patch(color=\"#f59e0b\", label=f\"Medium (6-11):  {((RISKS['Score']>=6)&(RISKS['Score']<12)).sum()}\"),\n",
    "    mpatches.Patch(color=\"#22c55e\", label=f\"Low (<6):       {(RISKS['Score']<6).sum()}\"),\n",
    "]\n",
