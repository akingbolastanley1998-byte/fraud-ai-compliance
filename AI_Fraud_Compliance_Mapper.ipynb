    "## 2. EU AI Act Requirements Graph\n",
    "\n",
    "This graph visualises the EU AI Act articles applicable to the fraud detection system and their relationships.  \n",
    "Node size reflects **centrality** (importance in the compliance network).  \n",
    "Edge labels show the **relationship type** between requirements.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "6f236278",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ══════════════════════════════════════════════════════════\n",
    "# EU AI ACT REQUIREMENTS GRAPH\n",
    "# Nodes = Articles/Requirements\n",
    "# Edges = Relationships (REQUIRES, SUPPORTS, REFERENCES)\n",
    "# ══════════════════════════════════════════════════════════\n",
    "\n",
    "G = nx.DiGraph()\n",
    "\n",
    "# ── Nodes ─────────────────────────────────────────────────\n",
    "nodes = {\n",
    "    # Core classification\n",
    "    \"Annex III\":    {\"type\": \"trigger\",  \"label\": \"Annex III\\nHigh-Risk\\nCategories\",   \"desc\": \"Designates high-risk AI applications\"},\n",
    "    \"Art.5\":        {\"type\": \"trigger\",  \"label\": \"Art. 5\\nProhibited\\nSystems\",         \"desc\": \"Lists prohibited AI uses\"},\n",
    "\n",
    "    # Primary obligations\n",
    "    \"Art.9\":        {\"type\": \"primary\",  \"label\": \"Art. 9\\nRisk Mgmt\\nSystem\",          \"desc\": \"Continuous risk management throughout lifecycle\"},\n",
    "    \"Art.10\":       {\"type\": \"primary\",  \"label\": \"Art. 10\\nData\\nGovernance\",           \"desc\": \"Training data relevance, bias examination\"},\n",
    "    \"Art.11\":       {\"type\": \"primary\",  \"label\": \"Art. 11\\nTechnical\\nDocumentation\",   \"desc\": \"Pre-deployment documentation requirements\"},\n",
    "    \"Art.12\":       {\"type\": \"primary\",  \"label\": \"Art. 12\\nRecord\\nKeeping\",            \"desc\": \"Automatic event logging for auditability\"},\n",
    "    \"Art.13\":       {\"type\": \"primary\",  \"label\": \"Art. 13\\nTransparency\",                \"desc\": \"Information provision to deployers/users\"},\n",
    "    \"Art.14\":       {\"type\": \"primary\",  \"label\": \"Art. 14\\nHuman\\nOversight\",           \"desc\": \"Human oversight measures\"},\n",
    "    \"Art.15\":       {\"type\": \"primary\",  \"label\": \"Art. 15\\nAccuracy &\\nRobustness\",     \"desc\": \"Performance, resilience, cybersecurity\"},\n",
    "\n",
    "    # Accountability\n",
    "    \"Art.25\":       {\"type\": \"account\",  \"label\": \"Art. 25\\nDeployer\\nObligations\",      \"desc\": \"Bank's duties as deployer\"},\n",
    "    \"Art.26\":       {\"type\": \"account\",  \"label\": \"Art. 26\\nProvider\\nObligations\",      \"desc\": \"ML vendor's duties as provider\"},\n",
    "    \"Art.17\":       {\"type\": \"account\",  \"label\": \"Art. 17\\nQuality\\nMgmt System\",       \"desc\": \"QMS requirements for providers\"},\n",
    "\n",
    "    # Parallel legal\n",
    "    \"UKGDPR.22\":    {\"type\": \"parallel\", \"label\": \"UK GDPR\\nArt. 22\\nAutomated Decisions\", \"desc\": \"Right to human review\"},\n",
    "    \"UKGDPR.1314\":  {\"type\": \"parallel\", \"label\": \"UK GDPR\\nArts. 13-14\\nTransparency\",    \"desc\": \"Privacy notice obligations\"},\n",
    "    \"FCA.Duty\":     {\"type\": \"parallel\", \"label\": \"FCA\\nConsumer Duty\\nPS22/9\",             \"desc\": \"Good customer outcomes\"},\n",
    "    \"EqAct.19\":     {\"type\": \"parallel\", \"label\": \"Equality Act\\ns.19\\nIndirect Discrim.\",  \"desc\": \"Bias in protected characteristics\"},\n",
    "}\n",
    "\n",
    "for nid, attrs in nodes.items():\n",
    "    G.add_node(nid, **attrs)\n",
    "\n",
    "# ── Edges ─────────────────────────────────────────────────\n",
    "edges = [\n",
    "    # Classification triggers obligations\n",
    "    (\"Annex III\", \"Art.9\",   \"TRIGGERS\"),\n",
    "    (\"Annex III\", \"Art.10\",  \"TRIGGERS\"),\n",
    "    (\"Annex III\", \"Art.11\",  \"TRIGGERS\"),\n",
    "    (\"Annex III\", \"Art.12\",  \"TRIGGERS\"),\n",
    "    (\"Annex III\", \"Art.13\",  \"TRIGGERS\"),\n",
    "    (\"Annex III\", \"Art.14\",  \"TRIGGERS\"),\n",
    "    (\"Annex III\", \"Art.15\",  \"TRIGGERS\"),\n",
    "    (\"Annex III\", \"Art.17\",  \"TRIGGERS\"),\n",
    "\n",
    "    # Internal dependencies\n",
    "    (\"Art.9\",    \"Art.10\",  \"REQUIRES\"),\n",
    "    (\"Art.9\",    \"Art.12\",  \"REQUIRES\"),\n",
    "    (\"Art.10\",   \"Art.15\",  \"SUPPORTS\"),\n",
    "    (\"Art.11\",   \"Art.12\",  \"REFERENCES\"),\n",
    "    (\"Art.13\",   \"Art.14\",  \"SUPPORTS\"),\n",
    "    (\"Art.14\",   \"Art.9\",   \"INFORMS\"),\n",
    "    (\"Art.15\",   \"Art.9\",   \"INFORMS\"),\n",
    "    (\"Art.17\",   \"Art.9\",   \"ENCOMPASSES\"),\n",
    "    (\"Art.17\",   \"Art.11\",  \"ENCOMPASSES\"),\n",
    "\n",
    "    # Accountability\n",
    "    (\"Art.25\",   \"Art.13\",  \"APPLIES\"),\n",
    "    (\"Art.25\",   \"Art.14\",  \"APPLIES\"),\n",
    "    (\"Art.26\",   \"Art.9\",   \"RESPONSIBLE\"),\n",
    "    (\"Art.26\",   \"Art.10\",  \"RESPONSIBLE\"),\n",
    "    (\"Art.26\",   \"Art.15\",  \"RESPONSIBLE\"),\n",
    "    (\"Art.26\",   \"Art.17\",  \"RESPONSIBLE\"),\n",
    "\n",
    "    # Cross-legal\n",
    "    (\"Art.13\",   \"UKGDPR.1314\", \"ALIGNS\"),\n",
    "    (\"Art.14\",   \"UKGDPR.22\",  \"ALIGNS\"),\n",
    "    (\"Art.10\",   \"EqAct.19\",   \"ALIGNS\"),\n",
    "    (\"Art.25\",   \"FCA.Duty\",   \"ALIGNS\"),\n",
    "    (\"UKGDPR.22\",\"UKGDPR.1314\",\"RELATED\"),\n",
    "    (\"Art.5\",    \"Annex III\",  \"CONTEXTUALISES\"),\n",
    "]\n",
    "\n",
    "for (src, tgt, rel) in edges:\n",
    "    G.add_edge(src, tgt, relation=rel)\n",
    "\n",
    "# ── Layout & Colours ──────────────────────────────────────\n",
    "colour_map = {\n",
    "    \"trigger\":  \"#ef4444\",\n",
    "    \"primary\":  \"#2563eb\",\n",
    "    \"account\":  \"#f59e0b\",\n",
    "    \"parallel\": \"#06b6d4\",\n",
    "}\n",
    "\n",
    "node_colours  = [colour_map[G.nodes[n][\"type\"]] for n in G.nodes]\n",
    "node_sizes    = [3000 + 500 * G.degree(n) for n in G.nodes]\n",
    "labels        = {n: G.nodes[n][\"label\"] for n in G.nodes}\n",
    "\n",
    "pos = nx.spring_layout(G, seed=42, k=2.8)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(18, 14))\n",
    "ax.set_facecolor('#0d1b2e')\n",
    "fig.patch.set_facecolor('#070d1a')\n",
    "\n",
    "# Draw edges by relation type\n",
    "edge_colours = {\"TRIGGERS\":\"#ef4444\",\"REQUIRES\":\"#3b82f6\",\"SUPPORTS\":\"#22c55e\",\n",
    "                \"REFERENCES\":\"#94a3b8\",\"ALIGNS\":\"#06b6d4\",\"APPLIES\":\"#f59e0b\",\n",
    "                \"RESPONSIBLE\":\"#f97316\",\"INFORMS\":\"#a78bfa\",\"ENCOMPASSES\":\"#ec4899\",\n",
    "                \"RELATED\":\"#64748b\",\"CONTEXTUALISES\":\"#ef4444\"}\n",
    "\n",
    "for (u,v,d) in G.edges(data=True):\n",
    "    ec = edge_colours.get(d[\"relation\"], \"#94a3b8\")\n",
    "    nx.draw_networkx_edges(G, pos, edgelist=[(u,v)], edge_color=ec,\n",
    "                           alpha=0.5, arrows=True, arrowsize=20,\n",
    "                           connectionstyle=\"arc3,rad=0.1\",\n",
    "                           width=1.5, ax=ax)\n",
    "\n",
    "nx.draw_networkx_nodes(G, pos, node_color=node_colours, node_size=node_sizes,\n",
    "                       alpha=0.9, ax=ax)\n",
    "nx.draw_networkx_labels(G, pos, labels=labels, font_size=7,\n",
    "                        font_color=\"white\", font_weight=\"bold\", ax=ax)\n",
    "\n",
    "# Legend\n",
    "legend_handles = [\n",
    "    mpatches.Patch(color=\"#ef4444\", label=\"Classification / Trigger\"),\n",
    "    mpatches.Patch(color=\"#2563eb\", label=\"Primary Obligation (Arts. 9-17)\"),\n",
    "    mpatches.Patch(color=\"#f59e0b\", label=\"Accountability (Deployer/Provider)\"),\n",
    "    mpatches.Patch(color=\"#06b6d4\", label=\"Parallel Legal Framework\"),\n",
    "]\n",
    "ax.legend(handles=legend_handles, loc=\"upper left\", facecolor=\"#112240\",\n",
    "          labelcolor=\"white\", framealpha=0.9, fontsize=10)\n",
    "\n",
    "ax.set_title(\"EU AI Act — Requirements Graph\\nAI-Driven Fraud Detection System | UK Retail Banking\",\n",
    "             color=\"white\", fontsize=14, fontweight=\"bold\", pad=20)\n",
    "ax.axis(\"off\")\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"eu_ai_act_requirements_graph.png\", dpi=150, bbox_inches=\"tight\",\n",
    "            facecolor=\"#070d1a\")\n",
    "plt.show()\n",
    "print(\"\\n✅ Graph saved: eu_ai_act_requirements_graph.png\")\n",
    "print(f\"   Nodes: {G.number_of_nodes()} | Edges: {G.number_of_edges()}\")\n",
    "print(f\"   Most central node: {max(nx.degree_centrality(G), key=nx.degree_centrality(G).get)}\")\n"
   ]
  },
